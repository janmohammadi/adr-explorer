{
  "name": "adr-explorer",
  "displayName": "ADR Explorer",
  "description": "Visualize Architecture Decision Records with timeline and graph views",
  "version": "0.1.0",
  "publisher": "adr-explorer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/adr/*.md",
    "workspaceContains:**/docs/adr/*.md",
    "workspaceContains:**/docs/decisions/*.md"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "adr-explorer",
          "title": "ADR Explorer",
          "icon": "resources/adr-icon.svg"
        }
      ]
    },
    "views": {
      "adr-explorer": [
        {
          "id": "adrExplorer.welcome",
          "name": "ADR Explorer"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "adrExplorer.welcome",
        "contents": "Visualize your Architecture Decision Records.\n[Open Explorer](command:adrExplorer.openExplorerView)\n[Refresh](command:adrExplorer.refresh)"
      }
    ],
    "commands": [
      {
        "command": "adrExplorer.openExplorerView",
        "title": "Open Explorer View",
        "category": "ADR Explorer",
        "icon": "$(layout)"
      },
      {
        "command": "adrExplorer.refresh",
        "title": "Refresh",
        "category": "ADR Explorer",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "adrExplorer.openExplorerView",
          "when": "view == adrExplorer.welcome",
          "group": "navigation@1"
        },
        {
          "command": "adrExplorer.refresh",
          "when": "view == adrExplorer.welcome",
          "group": "navigation@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "mermaid": "^11.4.0"
  }
}
