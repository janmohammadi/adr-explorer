{
  "name": "adr-explorer",
  "displayName": "ADR Explorer",
  "description": "Visualize Architecture Decision Records with timeline and graph views",
  "version": "0.1.0",
  "publisher": "adr-explorer",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/adr/*.md",
    "workspaceContains:**/docs/adr/*.md",
    "workspaceContains:**/docs/decisions/*.md"
  ],
  "contributes": {
    "commands": [
      {
        "command": "adrExplorer.open",
        "title": "Open ADR Explorer",
        "category": "ADR Explorer",
        "icon": "$(layout)"
      },
      {
        "command": "adrExplorer.refresh",
        "title": "Refresh",
        "category": "ADR Explorer",
        "icon": "$(refresh)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "tsc --noEmit",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "d3-drag": "^3.0.0",
    "d3-force": "^3.0.0",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "gray-matter": "^4.0.3",
    "marked": "^15.0.0",
    "mermaid": "^11.4.0"
  }
}
